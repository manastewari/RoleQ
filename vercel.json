{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm --workspace apps/web run build",
  "experimentalServices": {
    "web": {
      "root": "apps/web",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "api": {
      "root": "services/api",
      "entrypoint": "app.main:app",
      "routePrefix": "/_/api"
    }
  }
}
