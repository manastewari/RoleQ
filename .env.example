# Copy to .env at the repository root.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Judge0 CE works without a token for light local demos. A managed instance is recommended.
JUDGE0_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=
JUDGE0_AUTH_HEADER=X-Auth-Token

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production:
# NEXT_PUBLIC_API_URL=https://YOUR-RENDER-SERVICE.onrender.com
# CORS_ORIGINS=https://YOUR-PROJECT.vercel.app

# Supabase Auth. Use the public/publishable key, never the service-role key.
AUTH_MODE=supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Normal application operation uses PostgreSQL. Automated tests override this
# with an isolated SQLite database.
DATABASE_URL=postgresql+psycopg://intervue:intervue@127.0.0.1:5432/intervue
# For deployment, use the Supabase transaction-pooler database URL.
# Keep this secret and configure it only in the backend hosting provider.
# Used only by isolated AUTH_MODE=local_test automated tests.
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=720
